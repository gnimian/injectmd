{
  "name": "injectmd",
  "version": "1.0.0",
  "description": "tool to convert files to markdown or txt and inject them into AI chats",
  "main": "content.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "esbuild content.js --bundle --outfile=dist/contentBundle.js && esbuild popup.js --bundle --outfile=dist/popupBundle.js && npx @tailwindcss/cli -i ./input.css -o ./dist/tailwind.css"
  },
  "keywords": [
    "markdown",
    "pdf",
    "docx",
    "txt",
    "ai",
    "chatgpt",
    "claude",
    "gemini",
    "perplexity",
    "copilot",
    "grok"
  ],
  "author": "Naiming Zheng",
  "license": "MIT",
  "dependencies": {
    "@opendocsg/pdf2md": "^0.2.7",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.6.205",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.3.2"
  }
}
